User Function MA020TOK()

Local lRet := .t.

If M->A2_EST <> "EX" .and. Empty(M->A2_CGC)
	Aviso("Validaчуo - MA020TOK","Estс faltando informar o CNPJ e ou CPF do fornecedor ! Favor preencher o campo e confirmar em seguida.",{"Voltar"})	
	lRet := .f.
EndIf

Return( lRet )